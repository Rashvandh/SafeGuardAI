// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model Contact {
  id           String   @id @default(uuid())
  name         String
  phone        String
  relationship String   @default("Other")
  createdAt    DateTime @default(now())
}

model Report {
  id          String   @id @default(uuid())
  name        String
  location    String
  description String
  createdAt   DateTime @default(now())
}

model SOS {
  id        String   @id @default(uuid())
  lat       Float
  lng       Float
  timestamp DateTime @default(now())
}
